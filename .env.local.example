# Database (PostgreSQL directo - Coolify)
DATABASE_URL=postgresql://postgres:password@localhost:5432/leadpilot

# Auth (NextAuth.js)
# Genera con: openssl rand -base64 32
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# Encryption para API keys de clientes (genera con: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-key

# Instantly.ai (cold email)
INSTANTLY_API_KEY=your-instantly-api-key

# Outscraper (scraping Google Maps)
OUTSCRAPER_API_KEY=your-outscraper-api-key

# MillionVerifier (email verification)
MILLIONVERIFIER_API_KEY=your-millionverifier-api-key

# Anthropic (AI - Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
